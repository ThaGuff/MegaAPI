# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Get this from: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Admin panel protection
ADMIN_SECRET=change-me-to-a-strong-admin-password

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for outgoing emails (must be verified in Resend)
EMAIL_FROM=reports@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production, or * for development
CORS_ORIGIN=*

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Set to 'false' to disable the background job scheduler
ENABLE_SCHEDULER=true
