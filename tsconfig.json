{
  "compilerOptions": {
    "target":           "ESNext",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ESNext", "DOM"],
    "types":            ["bun-types"],
    "strict":           true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck":     true,
    "outDir":           "dist",
    "rootDir":          "src",
    "baseUrl":          ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit":           false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
